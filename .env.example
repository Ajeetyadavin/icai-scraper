# Environment Configuration
LOG_LEVEL=info

# ICAI Credentials (Required for login & search)
ICAI_USER_ID=your_icai_email@icai.org
ICAI_PASSWORD=your_icai_password

# Scraper Settings (Optional - can customize)
STUDENT_PREFIX=WRO
START_NUMBER=873000
RECORD_COUNT=100000

# Performance
CONCURRENCY=5
BATCH_SIZE=10000
SESSION_TIMEOUT=300000

# Paths (Optional - for local development only)
OUTPUT_DIR=./output
LOG_DIR=./logs
