{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...path].js"
    },
    {
      "source": "/styles.css",
      "destination": "/web/styles.css"
    },
    {
      "source": "/app.jsx",
      "destination": "/web/app.jsx"
    },
    {
      "source": "/(.*)",
      "destination": "/web/index.html"
    }
  ]
}